// ── Phase 58 — Live Match Console ───────────────────────────────────────────────
// A reusable single-match subsystem: timekeeper-anchored clock + append-only
// score log + login-free public scoreboard. Used standalone (Milestone 1), then
// by tournaments (Phase 32) and challenge matches (Phase 59).

enum MatchTableStatus {
  idle
  live
  paused
  done
}

// A scoring table. Tournament: N tables. Challenge: usually 1.
model MatchTable {
  id                String           @id @default(cuid())
  gymId             String? // host context (tournament gym / challenge host gym)
  tournamentId      String?
  challengeId       String? // Phase 59
  tournamentMatchId String?          @unique // link to a bracket match (propagate winner on finish)
  label             String // "Table 1", "Mat A"
  publicSlug        String           @unique // login-free scoreboard URL token
  status            MatchTableStatus @default(idle)
  createdById       String

  // competitors (denormalized names so the public scoreboard needs no joins/auth)
  aUserId String?
  aName   String?
  aClub   String?
  bUserId String?
  bName   String?
  bClub   String?

  // ruleset snapshot (see lib/rulesets.ts) — preset id + resolved config
  rulesetId     String?
  rulesetConfig Json?

  // clock state — timekeeper-anchored authoritative clock
  clockStatus String  @default("stopped") // 'stopped' | 'running'
  remainingMs Int     @default(0) // ms left at the anchor instant
  anchorTs    BigInt? // server-epoch ms of the timekeeper's press
  periodMs    Int     @default(300000) // length of the current period
  period      Int     @default(1) // 1-based period index

  winnerSide String? // 'a' | 'b' | null; set on finish
  winBy      String? // 'submission' | 'points' | 'decision' | 'dq' | 'forfeit'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments MatchTableAssignment[]
  events      MatchScoreEvent[]

  @@index([tournamentId])
  @@index([challengeId])
  @@index([createdById])
}

// Who can run this table. Granted via the "share with…" user search.
model MatchTableAssignment {
  id        String     @id @default(cuid())
  tableId   String
  userId    String
  canScore  Boolean    @default(true)
  canTime   Boolean    @default(true)
  createdAt DateTime   @default(now())
  table     MatchTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, userId])
  @@index([userId])
}

// Append-only event log = source of truth for the score; enables undo + audit.
model MatchScoreEvent {
  id        String     @id @default(cuid())
  tableId   String
  side      String? // 'a' | 'b' (null for clock/timeout/note)
  type      String // points | advantage | penalty | submission | disqualification | timeout | note | clock_adjust | win
  value     Int        @default(0) // e.g. points 2/3/4; advantage/penalty 1
  voided    Boolean    @default(false) // corrections: void instead of delete (audit trail)
  byUserId  String
  meta      Json? // clock_adjust deltas, note text, etc.
  createdAt DateTime   @default(now())
  table     MatchTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
}

// ── Phase 59 — Challenge Matches ────────────────────────────────────────────────
// Members opt in to accept challenges; another member proposes terms (time, host
// gym, ruleset, round length); both negotiate + accept; both sign the host gym's
// visitor waiver; host gym admin approves → scheduled; runs on the Phase 58 console;
// result feeds a competition record.

enum ChallengeStatus {
  proposed // challenger sent; awaiting challenged
  countered // someone changed terms; awaiting the other side
  accepted // both agree on terms; awaiting both signatures on the friendly-challenge waiver
  gym_pending // deprecated (pre-pivot gym-approval stage); retained for old rows
  scheduled // both signed the waiver — ready to run
  declined
  withdrawn
  completed
  cancelled
}

enum WaiverKind {
  membership
  visitor_challenge
}

// Gym-supplied legal waiver text/file (the gym owns the legal content).
model GymWaiver {
  id         String            @id @default(cuid())
  gymId      String
  kind       WaiverKind
  version    Int               @default(1)
  title      String
  body       String? // text waiver
  fileUrl    String? // or uploaded PDF
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  gym        Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  signatures WaiverSignature[]

  @@index([gymId])
}

// Typed-name e-signature of a waiver (audit trail). context = "challenge:<id>".
model WaiverSignature {
  id        String    @id @default(cuid())
  waiverId  String
  userId    String
  typedName String
  signedAt  DateTime  @default(now())
  ip        String?
  context   String?
  waiver    GymWaiver @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([waiverId, userId, context])
  @@index([userId])
}

model ChallengeMatch {
  id           String          @id @default(cuid())
  challengerId String
  challengedId String
  hostGymId    String?
  status       ChallengeStatus @default(proposed)

  // agreed terms (the current offer on the table)
  scheduledAt   DateTime?
  location      String?
  rulesetId     String?
  rulesetConfig Json?
  periodMs      Int? // agreed match length
  message       String? // optional note attached to the latest offer
  stipulations  String? // optional custom rules/conditions both sides agree to
  lastActorId   String? // who made the current offer (whose-turn logic)
  termsVersion  Int       @default(1)

  // Public-launch pivot — dual-signed platform "friendly challenge" waiver (no gym approval).
  waiverVersion        Int?
  challengerSignedName String?
  challengerSignedAt   DateTime?
  challengedSignedName String?
  challengedSignedAt   DateTime?

  listOnCalendar Boolean @default(false)
  publicEventId  String?

  // result
  winnerId String?
  winBy    String?

  expiresAt DateTime? // auto-expire stale pending (default +14d)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  challenger User                    @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User                    @relation("Challenged", fields: [challengedId], references: [id], onDelete: Cascade)
  hostGym    Gym?                    @relation(fields: [hostGymId], references: [id], onDelete: SetNull)
  terms      ChallengeTermsHistory[]

  @@index([challengerId])
  @@index([challengedId])
  @@index([hostGymId])
}

// Audit of each offer/counter-offer.
model ChallengeTermsHistory {
  id          String         @id @default(cuid())
  challengeId String
  byUserId    String
  terms       Json
  createdAt   DateTime       @default(now())
  challenge   ChallengeMatch @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
}
