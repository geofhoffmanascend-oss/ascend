// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  admin
  instructor
  student
  vendor
  site_admin
}

enum GymTier {
  free
  participating
  inactive
}

enum MembershipStatus {
  active
  pending
}

enum VendorType {
  photographer
  merchant
}

enum SubStatus {
  open
  filled
  cancelled
}

enum ClassType {
  gi
  nogi
  open_mat
  kids
  competition_prep
  seminar
  fundamentals
  nogi_fundamentals
  muay_thai
  wrestling
  self_defense
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum CommitmentStatus {
  committed
  maybe
  not_attending
}

enum LessonStatus {
  pending
  confirmed
  completed
  cancelled
}

enum Belt {
  white
  blue
  purple
  brown
  black
  coral
  red
}

enum ForumType {
  class_forum
  general
  announcement
  private_lesson
  instructor_only
  group_forum
  gym_forum
  belt_forum
  program_forum
}

enum PostType {
  text
  video_link
  question
  announcement
}

enum NotificationType {
  class_update
  instructor_note
  private_message
  checkin_prompt
  feedback_prompt
  new_follower
  followed_post
  general
}

enum CheckInSource {
  manual
  app
  qr_code
}

enum FeedbackSentiment {
  positive
  neutral
  negative
  concern
}

enum MessageRequestStatus {
  pending
  approved
  denied
}

enum MediaType {
  photo
  video_link
}

enum OrderStatus {
  pending
  ready
  picked_up
  cancelled
}

enum ClassGroup {
  grappling
  striking
  kids
  competition
  seminar
}

// ── Auth (NextAuth) ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  roles            Role[]    @default([student])
  vendorType       VendorType?
  onboardingDone   Boolean   @default(false)

  // Profile
  bio              String?
  phone            String?
  emergencyContact String?
  avatarUrl        String?
  profilePrivacy   Json    @default("{}")

  // Rank
  belt             Belt      @default(white)
  stripes          Int       @default(0)
  weightClass      String?

  // QR check-in token
  qrToken              String  @unique @default(cuid())

  // Journal settings
  defaultJournalPrompts String?

  // Notification preferences
  notifyClassUpdates    Boolean @default(true)
  notifyInstructorNotes Boolean @default(true)
  notifyPrivateMessages Boolean @default(true)
  notifyCheckinPrompts  Boolean @default(true)
  notifyFeedbackPrompts Boolean @default(true)
  notifyByEmail         Boolean @default(false)
  allowDmsFromStudents  Boolean @default(true)
  allowMediaTagging     Boolean @default(true)

  // Class access (admin-controlled membership restrictions)
  blockedClassGroups    ClassGroup[] @default([])
  // Phase 52 — admin-controlled access to gym-defined class programs (program ids)
  blockedProgramIds     String[]     @default([])
  // Schedule preferences (user-controlled visibility)
  hiddenClassGroups     ClassGroup[] @default([])
  // Phase 53 — member-hidden gym-defined class groups (schedule visibility, by program id)
  hiddenProgramIds      String[]     @default([])

  // Onboarding tracking — roles for which the onboarding wizard has been completed
  onboardedRoles        Role[]       @default([])

  // Gym affiliation
  gymId          String?   // home gym (nullable for unaffiliated users)
  beltVerified   Boolean   @default(false)
  beltVerifiedBy String?   // userId of the admin who verified

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // NextAuth relations
  accounts         Account[]
  sessions         Session[]

  // Gym relations
  gym            Gym?           @relation(fields: [gymId], references: [id], onDelete: SetNull)
  gymMemberships GymMembership[]

  // App relations
  taughtClasses        Class[]           @relation("ClassInstructor")
  commitments          Commitment[]
  attendanceRecords    Attendance[]
  lessonsRequested     PrivateLesson[]   @relation("LessonRequester")
  lessonsTeaching      PrivateLesson[]   @relation("LessonInstructor")
  lessonsAsUke         PrivateLesson[]   @relation("LessonUke")
  posts                Post[]
  forumSubscriptions   ForumSubscription[]
  forumReads           ForumRead[]
  following            Follow[]    @relation("Following")
  followers            Follow[]    @relation("Followers")
  sentInvitations      Invitation[] @relation("InviteInviter")
  instructorRequestedAt DateTime?   // Phase 40 — set when an "approve-after" instructor invite is accepted; cleared when the admin grants/denies
  acceptsOutsideOrg    Boolean      @default(false) // Phase 42 — instructor accepts private-lesson requests from outside their gym
  availability         InstructorAvailability[]
  postLikes            PostLike[]
  lastLoginAt          DateTime?
  loginEvents          LoginEvent[]
  goalsAsStudent       StudentGoal[]
  competitions         Competition[]
  rankHistory          RankPromotion[]   @relation("StudentRank")
  rankPromotionsGiven  RankPromotion[]   @relation("RankGivenBy")
  studentNotes         StudentNote[]     @relation("NoteSubject")
  instructorNotes      StudentNote[]     @relation("NoteAuthor")
  lessonPlansAuthored  LessonPlan[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  sentMessages         DirectMessage[]   @relation("SentMessages")
  receivedMessages     DirectMessage[]   @relation("ReceivedMessages")
  sentMessageRequests     MessageRequest[] @relation("SentRequests")
  receivedMessageRequests MessageRequest[] @relation("ReceivedRequests")
  uploadedMedia           MediaItem[]      @relation("UploaderMedia")
  mediaTags               MediaTag[]       @relation("TaggedInMedia")
  mediaAccessGrants       MediaAccess[]
  trainingLogs         TrainingLog[]
  classFeedback        ClassFeedback[]
  orders               Order[]
  subRequestsMade      ClassSubRequest[] @relation("SubRequestedBy")
  subRequestsClaimed   ClassSubRequest[] @relation("SubClaimedBy")
  trainingReflection   TrainingReflection?
  eventsSubmitted      PublicEvent[]  @relation("EventSubmitter")
  eventsApproved       PublicEvent[]  @relation("EventApprover")
  tournamentsCreated   Tournament[]   @relation("TournamentCreator")
  registrations        Registration[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ── Classes ────────────────────────────────────────────────────────────────────

model Class {
  id           String      @id @default(cuid())
  instructorId String
  title        String
  description  String?
  type         ClassType   @default(gi)
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  location     String?
  isActive     Boolean     @default(true)
  maxStudents  Int?
  gymId        String?
  programId    String?     // Phase 52 — gym-defined class program (Basics/Advanced/…)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  instructor   User        @relation("ClassInstructor", fields: [instructorId], references: [id])
  gym          Gym?        @relation(fields: [gymId], references: [id], onDelete: SetNull)
  program      ClassProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  sessions     ClassSession[]
  forum        Forum?
  lessonPlans  LessonPlan[]
}

// Phase 52 — a gym-defined grouping of classes (e.g. Basics, Advanced, Comp Team).
// Distinct from the fixed ClassGroup enum (which categorizes by class type).
model ClassProgram {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  classes     Class[]
  forum       Forum?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gymId, name])
}

model ClassSession {
  id           String    @id @default(cuid())
  classId      String
  date         DateTime  @db.Date
  cancelled    Boolean   @default(false)
  cancelNote   String?
  notes        String?
  sessionNotes String?
  notesPublic  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  class        Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  commitments  Commitment[]
  attendance   Attendance[]
  trainingLogs TrainingLog[]
  feedback     ClassFeedback[]
  subRequests  ClassSubRequest[]

  @@unique([classId, date])
}

model ClassSubRequest {
  id             String    @id @default(cuid())
  classSessionId String
  requestedById  String
  claimedById    String?
  status         SubStatus @default(open)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("SubRequestedBy", fields: [requestedById], references: [id])
  claimedBy    User?        @relation("SubClaimedBy", fields: [claimedById], references: [id])
}

model Commitment {
  id             String           @id @default(cuid())
  userId         String
  classSessionId String
  status         CommitmentStatus @default(committed)
  weightClass    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

model Attendance {
  id             String        @id @default(cuid())
  userId         String
  classSessionId String
  attended       Boolean       @default(true)
  markedById     String
  checkedInAt    DateTime?
  checkInSource  CheckInSource @default(manual)
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id])
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

// ── Private Lessons ────────────────────────────────────────────────────────────

// Phase 42 — instructor private-lesson availability
enum AvailabilityKind {
  recurring // weekly window (uses dayOfWeek)
  oneoff    // single dated bookable window (uses date)
  block     // exception that removes availability (uses date)
}

model InstructorAvailability {
  id           String           @id @default(cuid())
  instructorId String
  instructor   User             @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  kind         AvailabilityKind
  dayOfWeek    DayOfWeek?       // recurring
  date         DateTime?        // oneoff / block
  startTime    String           // "HH:mm"
  endTime      String           // "HH:mm"
  gymId        String?          // gym this availability is offered at
  createdAt    DateTime         @default(now())

  @@index([instructorId])
}

model PrivateLesson {
  id           String        @id @default(cuid())
  requesterId  String
  instructorId String
  ukeId        String?
  scheduledAt  DateTime
  durationMins Int           @default(60)
  status       LessonStatus  @default(pending)
  location     String?
  notes        String?
  price        Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  requester    User          @relation("LessonRequester", fields: [requesterId], references: [id])
  instructor   User          @relation("LessonInstructor", fields: [instructorId], references: [id])
  uke          User?         @relation("LessonUke", fields: [ukeId], references: [id])
  messages     LessonMessage[]
}

model LessonMessage {
  id        String   @id @default(cuid())
  lessonId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  lesson PrivateLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ── Forums & Posts ─────────────────────────────────────────────────────────────

model Forum {
  id          String     @id @default(cuid())
  type        ForumType
  classId     String?    @unique
  classGroup  ClassGroup?
  gymId       String?
  programId   String?    @unique  // Phase 52 — dedicated forum for a ClassProgram
  beltLevel   Belt?
  title       String
  description String?
  createdAt   DateTime   @default(now())

  class         Class?             @relation(fields: [classId], references: [id], onDelete: Cascade)
  gym           Gym?               @relation(fields: [gymId], references: [id], onDelete: SetNull)
  // Class-group forum survives if its class group is deleted (Phase 52) — it just
  // detaches (programId → null) and remains until an admin deletes it.
  program       ClassProgram?      @relation(fields: [programId], references: [id], onDelete: SetNull)
  posts         Post[]
  subscriptions ForumSubscription[]
  reads         ForumRead[]
  media         MediaItem[]
}

model Post {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  content   String
  type      PostType @default(text)
  videoUrl  String?
  imageUrl  String?
  parentId  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum    Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author   User   @relation(fields: [authorId], references: [id])
  parent   Post?  @relation("PostReplies", fields: [parentId], references: [id])
  replies  Post[] @relation("PostReplies")
  likes    PostLike[]
  media    MediaItem?
}

// Thumbs-up reaction on a forum post (one per user per post).
model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model ForumSubscription {
  id        String   @id @default(cuid())
  userId    String
  forumId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
}

// One login record per sign-in. Powers admin "logins in last 30 days" stats.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// One-way user→user follow (no approval). Drives the activity feed + post notifications.
// Phase 40 — invitations
enum InviteKind {
  friend
  gym_member
  gym_instructor
}

model Invitation {
  id           String     @id @default(cuid())
  token        String     @unique
  inviterId    String
  inviter      User       @relation("InviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  kind         InviteKind
  gymId        String?    // for gym_member / gym_instructor
  grantOnAccept Boolean   @default(true) // instructor: true = single-use grant; false = approve-after
  maxUses      Int?       // null = unlimited (reusable friend link)
  usedCount    Int        @default(0)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  redemptions  InviteRedemption[]
}

model InviteRedemption {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId       String     // redeemer (no relation needed)
  createdAt    DateTime   @default(now())

  @@unique([invitationId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// Per-user read marker for a forum (decoupled from subscription/notifications).
// Updated whenever a user opens a forum; used to compute unread counts + ordering.
model ForumRead {
  id         String   @id @default(cuid())
  userId     String
  forumId    String
  lastReadAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
}

// ── Student Profile ────────────────────────────────────────────────────────────

model StudentGoal {
  id          String    @id @default(cuid())
  userId      String
  description String
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competition {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        DateTime @db.Date
  location    String?
  division    String?
  weightClass String?
  result      String?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RankPromotion {
  id           String   @id @default(cuid())
  studentId    String
  promotedById String
  belt         Belt
  stripes      Int
  date         DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now())

  student     User @relation("StudentRank", fields: [studentId], references: [id])
  promotedBy  User @relation("RankGivenBy", fields: [promotedById], references: [id])
}

// ── Instructor Tools ───────────────────────────────────────────────────────────

model StudentNote {
  id           String   @id @default(cuid())
  studentId    String
  instructorId String
  content      String
  isPrivate    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    User @relation("NoteSubject", fields: [studentId], references: [id], onDelete: Cascade)
  instructor User @relation("NoteAuthor", fields: [instructorId], references: [id])
}

model LessonPlan {
  id           String   @id @default(cuid())
  instructorId String
  classId      String?
  title        String
  techniques   String?
  notes        String?
  videoUrls    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor User   @relation(fields: [instructorId], references: [id])
  class      Class? @relation(fields: [classId], references: [id])
}

// ── Notifications ──────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

// ── Direct Messages ────────────────────────────────────────────────────────────

model DirectMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("SentMessages",     fields: [senderId],    references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

// ── Message Requests ──────────────────────────────────────────────────────────

model MessageRequest {
  id             String               @id @default(cuid())
  senderId       String
  sender         User                 @relation("SentRequests",     fields: [senderId],    references: [id], onDelete: Cascade)
  recipientId    String
  recipient      User                 @relation("ReceivedRequests", fields: [recipientId], references: [id], onDelete: Cascade)
  initialMessage String
  status         MessageRequestStatus @default(pending)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([senderId, recipientId])
}

// ── Training Journal ───────────────────────────────────────────────────────────

model TrainingLog {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId  String?
  classSession    ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  title           String?
  isPrivate       Boolean       @default(false)
  isGuided        Boolean       @default(false)
  freeFormContent String?
  guidedResponses Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── Class Feedback ─────────────────────────────────────────────────────────────

model ClassFeedback {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId  String
  classSession    ClassSession      @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  sentiment       FeedbackSentiment
  rating          Int?
  responses       Json
  reviewRequested Boolean           @default(false)
  anonymous       Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@unique([userId, classSessionId])
}

// ── Media Archive ─────────────────────────────────────────────────────────────

model MediaItem {
  id           String          @id @default(cuid())
  uploaderId   String
  uploader     User            @relation("UploaderMedia", fields: [uploaderId], references: [id], onDelete: Cascade)
  url          String
  publicId     String?
  thumbnailUrl String?
  type         MediaType
  caption      String?
  forSale      Boolean         @default(false)
  price        Int?
  gymId        String?
  visibility   MediaVisibility @default(public)
  createdAt    DateTime        @default(now())
  gym          Gym?            @relation(fields: [gymId], references: [id], onDelete: SetNull)
  tags         MediaTag[]
  hashtags     MediaHashtag[]
  accessGrants MediaAccess[]
  // Per-forum gallery (Phase 49): media scoped to a forum, linked to its source post.
  forumId      String?
  forum        Forum?          @relation(fields: [forumId], references: [id], onDelete: Cascade)
  postId       String?         @unique
  post         Post?           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([forumId])
}

model MediaAccess {
  id          String    @id @default(cuid())
  mediaItemId String
  userId      String
  createdAt   DateTime  @default(now())

  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaItemId, userId])
}

model Hashtag {
  id        String         @id @default(cuid())
  tag       String         @unique
  createdAt DateTime       @default(now())
  media     MediaHashtag[]
}

model MediaHashtag {
  mediaItemId String
  hashtagId   String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  hashtag     Hashtag   @relation(fields: [hashtagId],   references: [id], onDelete: Cascade)

  @@id([mediaItemId, hashtagId])
}

model MediaTag {
  id          String    @id @default(cuid())
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("TaggedInMedia", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([mediaItemId, userId])
}

// ── Push Subscriptions ─────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ── Gym ────────────────────────────────────────────────────────────────────────

model Gym {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  address             String?
  city                String?
  state               String?
  zip                 String?
  phone               String?
  website             String?
  logoUrl             String?
  headInstructorName  String?
  description         String?
  participatingStatus GymTier   @default(free)
  paymentTerms        Json?
  setupProgress       Json?     // Phase 38.3 — owner setup checklist completion, e.g. {schedule:true,instructors:false,logo:true,roster:false}
  lat                 Float?    // Phase 42 — geocoded (Google Maps) for radius search
  lng                 Float?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  members      GymMembership[]
  users        User[]
  classes      Class[]
  forums       Forum[]
  media        MediaItem[]
  products     Product[]
  orders       Order[]
  settings     GymSettings[]
  publicEvents PublicEvent[]
  tournaments  Tournament[]
  features     GymFeatures?
  classPrograms ClassProgram[]
}

// Per-gym feature toggles (Phase 37). Gym admins turn optional features on/off
// for their own gym. Combined with PlatformSettings (Phase 33): a feature is on
// only if the platform allows it AND the gym allows it. Missing row = all on.
model GymFeatures {
  id                    String   @id @default(cuid())
  gymId                 String   @unique
  gym                   Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  storeEnabled          Boolean  @default(true)
  tournamentsEnabled    Boolean  @default(true)
  galleryEnabled        Boolean  @default(true) // gallery visible/browsable
  galleryUploadEnabled  Boolean  @default(true) // new uploads allowed
  privateLessonsEnabled Boolean  @default(true)
  gymForumEnabled       Boolean  @default(true)
  journalEnabled        Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model GymMembership {
  id       String           @id @default(cuid())
  userId   String
  gymId    String
  status   MembershipStatus @default(active)
  joinedAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
}

// ── Gym Settings ───────────────────────────────────────────────────────────────

model GymSettings {
  id        String   @id @default(cuid())
  gymId     String?  @unique
  gym       Gym?     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  reviewUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Gear Store ─────────────────────────────────────────────────────────────────

model Product {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Int
  imageUrl      String?
  stock         Int         @default(0)
  available     Boolean     @default(true)
  category      String?
  gymId         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  gym           Gym?        @relation(fields: [gymId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[]
  status    OrderStatus @default(pending)
  notes     String?
  gymId     String?
  gym       Gym?        @relation(fields: [gymId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Int
}

enum ReflectionPrivacy {
  public
  members
  private
}

model TrainingReflection {
  id          String             @id @default(cuid())
  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  whyStarted  String?
  challenges  String?
  goals       String?
  privacy     ReflectionPrivacy  @default(private)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  userId    String
  newEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum MediaVisibility {
  public
  gym_only
  private
  custom
}

enum PublicEventType {
  open_mat
  competition
  seminar
  other
}

enum PublicEventStatus {
  pending
  approved
  rejected
}

model PublicEvent {
  id            String            @id @default(cuid())
  title         String
  type          PublicEventType
  description   String?
  location      String?
  address       String?
  city          String?
  state         String?
  zip           String?
  startDate     DateTime
  endDate       DateTime?
  submittedById String
  gymId         String?
  status        PublicEventStatus @default(pending)
  rejectionNote String?
  approvedById  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  submittedBy  User  @relation("EventSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  approvedBy   User? @relation("EventApprover",  fields: [approvedById],  references: [id], onDelete: SetNull)
  gym          Gym?  @relation(fields: [gymId], references: [id], onDelete: SetNull)
}

enum TournamentFormat {
  round_robin
  single_elim
  double_elim
}

enum TournamentStatus {
  draft
  open
  in_progress
  complete
}

enum MatchResult {
  pending
  participant_a_wins
  participant_b_wins
  draw
  bye
}

model Tournament {
  id          String           @id @default(cuid())
  gymId       String
  title       String
  description String?
  date        DateTime
  format      TournamentFormat
  status      TournamentStatus @default(draft)
  isPublic    Boolean          @default(false)
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  divisions   Division[]
}

model Division {
  id            String         @id @default(cuid())
  tournamentId  String
  name          String
  beltMin       Belt
  beltMax       Belt
  weightClass   String?
  ageGroup      String?
  createdAt     DateTime       @default(now())

  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registrations Registration[]
  matches       TournamentMatch[]
}

model Registration {
  id           String   @id @default(cuid())
  divisionId   String
  userId       String
  confirmed    Boolean  @default(false)
  seed         Int?
  createdAt    DateTime @default(now())

  division     Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([divisionId, userId])
}

model TournamentMatch {
  id            String      @id @default(cuid())
  divisionId    String
  round         Int
  position      Int
  participantA  String?
  participantB  String?
  result        MatchResult @default(pending)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  division      Division    @relation(fields: [divisionId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                        String   @id @default("singleton")
  // Feature toggles — all default to true (on). Set false to disable before launch.
  allowGymForumCreation     Boolean  @default(true)
  allowBeltForumPosting     Boolean  @default(true)
  allowEventSubmission      Boolean  @default(true)
  allowTournamentRegistration Boolean @default(true)
  scheduleReadOnly          Boolean  @default(false)
  galleryEnabled            Boolean  @default(true) // gallery visible/browsable
  galleryUploadEnabled      Boolean  @default(true) // new uploads allowed
  storeEnabled              Boolean  @default(true)
  // Navbar-link visibility toggles (platform-wide; admins always see them)
  feedEnabled               Boolean  @default(true)
  scheduleEnabled           Boolean  @default(true)
  forumsEnabled             Boolean  @default(true)
  eventsEnabled             Boolean  @default(true)
  updatedAt                 DateTime @updatedAt
}
