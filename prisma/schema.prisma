// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  admin
  instructor
  student
  vendor
  site_admin
}

enum GymTier {
  free
  participating
  inactive
}

enum MembershipStatus {
  active
  pending
}

enum VendorType {
  photographer
  merchant
}

enum SubStatus {
  open
  filled
  cancelled
}

enum ClassType {
  gi
  nogi
  open_mat
  kids
  competition_prep
  seminar
  fundamentals
  nogi_fundamentals
  muay_thai
  wrestling
  self_defense
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum CommitmentStatus {
  committed
  maybe
  not_attending
}

enum LessonStatus {
  pending
  confirmed
  completed
  cancelled
}

enum Belt {
  white
  blue
  purple
  brown
  black
  coral
  red
}

enum ForumType {
  class_forum
  general
  announcement
  private_lesson
  instructor_only
  group_forum
  gym_forum
  belt_forum
  program_forum
  group_chat
}

enum PostType {
  text
  video_link
  question
  announcement
}

enum NotificationType {
  class_update
  instructor_note
  private_message
  checkin_prompt
  feedback_prompt
  new_follower
  followed_post
  general
}

enum CheckInSource {
  manual
  app
  qr_code
}

enum FeedbackSentiment {
  positive
  neutral
  negative
  concern
}

enum MessageRequestStatus {
  pending
  approved
  denied
}

// Phase 61 — a user's own recurring training slot, independent of any gym schedule.
model PersonalClass {
  id        String    @id @default(cuid())
  userId    String
  label     String
  type      ClassType @default(gi)
  dayOfWeek DayOfWeek
  startTime String // "18:00"
  endTime   String?
  location  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns SelfCheckIn[]

  @@index([userId])
}

// Phase 61 — a logged training day (gym-independent). Feeds the same streak/attendance UI.
model SelfCheckIn {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  personalClassId String?
  label           String? // snapshot of the slot label, or an ad-hoc note
  note            String?
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalClass PersonalClass? @relation(fields: [personalClassId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

// Phase 60 — per-feature feedback gathered during the onboarding/feature tour.
// userId is nullable so anonymous pre-onboarding viewers can submit.
model TourFeedback {
  id         String   @id @default(cuid())
  userId     String?
  role       String // 'member' | 'gym' | 'instructor'
  featureKey String // step featureKey, or 'overall:<q>' for the end survey
  rating     Int? // 1 = 👍, -1 = 👎, or 0..10 for NPS
  comment    String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([role, featureKey])
}

enum MediaType {
  photo
  video_link
}

enum OrderStatus {
  pending
  ready
  picked_up
  cancelled
}

enum ClassGroup {
  grappling
  striking
  kids
  competition
  seminar
}

// ── Auth (NextAuth) ────────────────────────────────────────────────────────────

model User {
  id             String      @id @default(cuid())
  name           String?
  email          String      @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  roles          Role[]      @default([student])
  vendorType     VendorType?
  onboardingDone Boolean     @default(false)

  // Profile
  bio              String?
  phone            String?
  emergencyContact String?
  avatarUrl        String?
  profilePrivacy   Json    @default("{}")

  // Rank
  belt        Belt    @default(white)
  stripes     Int     @default(0)
  weightClass String?

  // QR check-in token
  qrToken String @unique @default(cuid())

  // Journal settings
  defaultJournalPrompts String?

  // Notification preferences
  notifyClassUpdates    Boolean @default(true)
  notifyInstructorNotes Boolean @default(true)
  notifyPrivateMessages Boolean @default(true)
  notifyCheckinPrompts  Boolean @default(true)
  notifyFeedbackPrompts Boolean @default(true)
  notifyByEmail         Boolean @default(false)
  allowDmsFromStudents  Boolean @default(true)
  allowMediaTagging     Boolean @default(true)
  notifyGroupChats      Boolean @default(true) // new messages in group chats
  notifyForumActivity   Boolean @default(true) // new posts in forums you're subscribed to

  // Class access (admin-controlled membership restrictions)
  blockedClassGroups ClassGroup[] @default([])
  // Phase 52 — admin-controlled access to gym-defined class programs (program ids)
  blockedProgramIds  String[]     @default([])
  // Schedule preferences (user-controlled visibility)
  hiddenClassGroups  ClassGroup[] @default([])
  // Phase 53 — member-hidden gym-defined class groups (schedule visibility, by program id)
  hiddenProgramIds   String[]     @default([])

  // Onboarding tracking — roles for which the onboarding wizard has been completed
  onboardedRoles Role[] @default([])

  // Gym affiliation
  gymId          String? // home gym (nullable for unaffiliated users)
  beltVerified   Boolean @default(false)
  beltVerifiedBy String? // userId of the admin who verified

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Gym relations
  gym            Gym?            @relation(fields: [gymId], references: [id], onDelete: SetNull)
  gymMemberships GymMembership[]
  gymClaims      GymClaim[]      @relation("GymClaims")

  // App relations
  taughtClasses         Class[]             @relation("ClassInstructor")
  commitments           Commitment[]
  attendanceRecords     Attendance[]
  lessonsRequested      PrivateLesson[]     @relation("LessonRequester")
  lessonsTeaching       PrivateLesson[]     @relation("LessonInstructor")
  lessonsAsUke          PrivateLesson[]     @relation("LessonUke")
  posts                 Post[]
  forumSubscriptions    ForumSubscription[]
  forumReads            ForumRead[]
  following             Follow[]            @relation("Following")
  followers             Follow[]            @relation("Followers")
  sentInvitations       Invitation[]        @relation("InviteInviter")
  instructorRequestedAt DateTime? // Phase 40 — set when an "approve-after" instructor invite is accepted; cleared when the admin grants/denies
  acceptsOutsideOrg     Boolean             @default(false) // Phase 42 — instructor accepts private-lesson requests from outside their gym

  // Phase 42.4 — independent (non-gym) private-lesson provider, vetted by a verified black belt.
  providerStatus       ProviderStatus @default(none)
  providerApprovedById String?
  providerApprovedAt   DateTime?
  providerBio          String?
  providerCity         String?
  providerState        String?
  providerLat          Float?
  providerLng          Float?

  // Phase 56 — cached aggregate of private-lesson reviews received (as instructor).
  ratingAvg               Float?
  ratingCount             Int                      @default(0)
  reviewsReceived         InstructorReview[]       @relation("ReviewInstructor")
  reviewsWritten          InstructorReview[]       @relation("ReviewReviewer")
  availability            InstructorAvailability[]
  postLikes               PostLike[]
  lastLoginAt             DateTime?
  loginEvents             LoginEvent[]
  goalsAsStudent          StudentGoal[]
  competitions            Competition[]
  rankHistory             RankPromotion[]          @relation("StudentRank")
  rankPromotionsGiven     RankPromotion[]          @relation("RankGivenBy")
  studentNotes            StudentNote[]            @relation("NoteSubject")
  instructorNotes         StudentNote[]            @relation("NoteAuthor")
  lessonPlansAuthored     LessonPlan[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  sentMessages            DirectMessage[]          @relation("SentMessages")
  receivedMessages        DirectMessage[]          @relation("ReceivedMessages")
  sentMessageRequests     MessageRequest[]         @relation("SentRequests")
  receivedMessageRequests MessageRequest[]         @relation("ReceivedRequests")
  uploadedMedia           MediaItem[]              @relation("UploaderMedia")
  mediaTags               MediaTag[]               @relation("TaggedInMedia")
  mediaAccessGrants       MediaAccess[]
  trainingLogs            TrainingLog[]
  classFeedback           ClassFeedback[]
  orders                  Order[]
  subRequestsMade         ClassSubRequest[]        @relation("SubRequestedBy")
  subRequestsClaimed      ClassSubRequest[]        @relation("SubClaimedBy")
  trainingReflection      TrainingReflection?
  eventsSubmitted         PublicEvent[]            @relation("EventSubmitter")
  eventsApproved          PublicEvent[]            @relation("EventApprover")
  tournamentsCreated      Tournament[]             @relation("TournamentCreator")
  registrations           Registration[]

  // Phase 59 — challenge matches
  competeTournaments Boolean           @default(false)
  acceptsChallenges  Boolean           @default(false)
  challengesSent     ChallengeMatch[]  @relation("Challenger")
  challengesReceived ChallengeMatch[]  @relation("Challenged")
  waiverSignatures   WaiverSignature[]

  // Phase 60 — onboarding/feature tour
  tourSeenRoles Role[]         @default([]) // tour roles ('student' member / 'admin' gym / 'instructor') already auto-offered
  tourFeedback  TourFeedback[]

  // Phase 61 — personal (gym-independent) training schedule & self-tracking
  personalClasses PersonalClass[]
  selfCheckIns    SelfCheckIn[]

  // Public-launch pivot — private self-identification (label only, NO admin powers).
  selfIdInstructor Boolean @default(false)
  selfIdGymOwner   Boolean @default(false)

  // Public-launch pivot — group-chat join requests
  forumJoinRequests ForumJoinRequest[]

  // Public-launch pivot — feature-intro modals the user chose "don't show again" for (by featureKey)
  dismissedIntros String[] @default([])

  // App-wide user feedback (floating feedback button)
  feedback Feedback[]

  // Private-instructor application (vetting/background-check data)
  providerApplication ProviderApplication?
}

// Private-instructor vetting application — collected on apply, reviewed by a verified
// black belt / site admin before the applicant is listed. Holds the sensitive info
// needed to verify credentials and run a background check.
model ProviderApplication {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String? // full legal name
  dateOfBirth       String? // "YYYY-MM-DD"
  contactEmail      String?
  contactPhone      String?
  instructorName    String? // the black belt they train under
  instructorContact String? // that instructor's / gym's contact (email or phone)
  gymName           String?
  countiesLived     String? // counties/states lived in over the last 5 years
  arrestLast5       Boolean  @default(false)
  arrestDetails     String? // explanation if arrestLast5 is true
  consent           Boolean  @default(false) // authorizes the background check + instructor contact
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// General in-app user feedback (ratings + short answers) from the floating feedback button.
model Feedback {
  id                String   @id @default(cuid())
  userId            String?
  userEmail         String? // cached for display
  userName          String? // cached for display
  ratingOverall     Int? // 1–5
  ratingDisplay     Int? // 1–5
  ratingNavigation  Int? // 1–5
  ratingPerformance Int? // 1–5
  changeRequest     String?
  missingFeatures   String?
  improvement       String?
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Classes ────────────────────────────────────────────────────────────────────

model Class {
  id           String    @id @default(cuid())
  instructorId String
  title        String
  description  String?
  type         ClassType @default(gi)
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  location     String?
  isActive     Boolean   @default(true)
  maxStudents  Int?
  gymId        String?
  programId    String? // Phase 52 — gym-defined class program (Basics/Advanced/…)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  instructor  User           @relation("ClassInstructor", fields: [instructorId], references: [id])
  gym         Gym?           @relation(fields: [gymId], references: [id], onDelete: SetNull)
  program     ClassProgram?  @relation(fields: [programId], references: [id], onDelete: SetNull)
  sessions    ClassSession[]
  forum       Forum?
  lessonPlans LessonPlan[]
}

// Phase 52 — a gym-defined grouping of classes (e.g. Basics, Advanced, Comp Team).
// Distinct from the fixed ClassGroup enum (which categorizes by class type).
model ClassProgram {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  classes     Class[]
  forum       Forum?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([gymId, name])
}

model ClassSession {
  id           String   @id @default(cuid())
  classId      String
  date         DateTime @db.Date
  cancelled    Boolean  @default(false)
  cancelNote   String?
  notes        String?
  sessionNotes String?
  notesPublic  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  class        Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  commitments  Commitment[]
  attendance   Attendance[]
  trainingLogs TrainingLog[]
  feedback     ClassFeedback[]
  subRequests  ClassSubRequest[]

  @@unique([classId, date])
}

model ClassSubRequest {
  id             String    @id @default(cuid())
  classSessionId String
  requestedById  String
  claimedById    String?
  status         SubStatus @default(open)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("SubRequestedBy", fields: [requestedById], references: [id])
  claimedBy    User?        @relation("SubClaimedBy", fields: [claimedById], references: [id])
}

model Commitment {
  id             String           @id @default(cuid())
  userId         String
  classSessionId String
  status         CommitmentStatus @default(committed)
  weightClass    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

model Attendance {
  id             String        @id @default(cuid())
  userId         String
  classSessionId String
  attended       Boolean       @default(true)
  markedById     String
  checkedInAt    DateTime?
  checkInSource  CheckInSource @default(manual)
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id])
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

// ── Private Lessons ────────────────────────────────────────────────────────────

// Phase 42 — instructor private-lesson availability
enum AvailabilityKind {
  recurring // weekly window (uses dayOfWeek)
  oneoff // single dated bookable window (uses date)
  block // exception that removes availability (uses date)
}

model InstructorAvailability {
  id           String           @id @default(cuid())
  instructorId String
  instructor   User             @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  kind         AvailabilityKind
  dayOfWeek    DayOfWeek? // recurring
  date         DateTime? // oneoff / block
  startTime    String // "HH:mm"
  endTime      String // "HH:mm"
  gymId        String? // gym this availability is offered at
  createdAt    DateTime         @default(now())

  @@index([instructorId])
}

model PrivateLesson {
  id           String       @id @default(cuid())
  requesterId  String
  instructorId String
  ukeId        String?
  scheduledAt  DateTime
  durationMins Int          @default(60)
  status       LessonStatus @default(pending)
  location     String?
  notes        String?
  price        Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  requester  User              @relation("LessonRequester", fields: [requesterId], references: [id])
  instructor User              @relation("LessonInstructor", fields: [instructorId], references: [id])
  uke        User?             @relation("LessonUke", fields: [ukeId], references: [id])
  messages   LessonMessage[]
  review     InstructorReview?
}

// Phase 56 — a private-lesson review. One per completed lesson (lessonId unique),
// written by the lesson's requester about the instructor.
model InstructorReview {
  id           String        @id @default(cuid())
  lessonId     String        @unique
  lesson       PrivateLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User          @relation("ReviewInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User          @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  rating       Int // 1..5
  comment      String?
  createdAt    DateTime      @default(now())

  @@index([instructorId])
}

model LessonMessage {
  id        String   @id @default(cuid())
  lessonId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  lesson PrivateLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ── Forums & Posts ─────────────────────────────────────────────────────────────

model Forum {
  id          String      @id @default(cuid())
  type        ForumType
  classId     String?     @unique
  classGroup  ClassGroup?
  gymId       String?
  programId   String?     @unique // Phase 52 — dedicated forum for a ClassProgram
  beltLevel   Belt?
  title       String
  description String?
  createdById String? // Public-launch pivot — creator/owner of a group_chat
  createdAt   DateTime    @default(now())

  class         Class?              @relation(fields: [classId], references: [id], onDelete: Cascade)
  gym           Gym?                @relation(fields: [gymId], references: [id], onDelete: SetNull)
  // Class-group forum survives if its class group is deleted (Phase 52) — it just
  // detaches (programId → null) and remains until an admin deletes it.
  program       ClassProgram?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  posts         Post[]
  subscriptions ForumSubscription[]
  reads         ForumRead[]
  media         MediaItem[]
  joinRequests  ForumJoinRequest[]
}

// Public-launch pivot — request to join a group_chat; any current member approves.
model ForumJoinRequest {
  id        String   @id @default(cuid())
  forumId   String
  userId    String
  status    String   @default("pending") // pending | approved | declined
  createdAt DateTime @default(now())

  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
}

model Post {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  content   String
  type      PostType @default(text)
  videoUrl  String?
  imageUrl  String?
  parentId  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum   Forum      @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author  User       @relation(fields: [authorId], references: [id])
  parent  Post?      @relation("PostReplies", fields: [parentId], references: [id])
  replies Post[]     @relation("PostReplies")
  likes   PostLike[]
  media   MediaItem?
}

// Thumbs-up reaction on a forum post (one per user per post).
model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model ForumSubscription {
  id        String   @id @default(cuid())
  userId    String
  forumId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
}

// One login record per sign-in. Powers admin "logins in last 30 days" stats.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// One-way user→user follow (no approval). Drives the activity feed + post notifications.
// Phase 40 — invitations
enum InviteKind {
  friend
  gym_member
  gym_instructor
}

// Phase 42.4 — independent private-lesson provider approval state.
enum ProviderStatus {
  none
  pending
  approved
  rejected
}

model Invitation {
  id            String             @id @default(cuid())
  token         String             @unique
  inviterId     String
  inviter       User               @relation("InviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  kind          InviteKind
  gymId         String? // for gym_member / gym_instructor
  grantOnAccept Boolean            @default(true) // instructor: true = single-use grant; false = approve-after
  maxUses       Int? // null = unlimited (reusable friend link)
  usedCount     Int                @default(0)
  email         String? // Phase 40.2 — bulk CSV invite targeted at this email (auto-applied on signup)
  meta          Json? // Phase 40.2 — prefill from CSV: { name?, belt?, phone?, notes? }
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  redemptions   InviteRedemption[]

  @@index([email])
}

model InviteRedemption {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId       String // redeemer (no relation needed)
  createdAt    DateTime   @default(now())

  @@unique([invitationId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// Per-user read marker for a forum (decoupled from subscription/notifications).
// Updated whenever a user opens a forum; used to compute unread counts + ordering.
model ForumRead {
  id         String   @id @default(cuid())
  userId     String
  forumId    String
  lastReadAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
}

// ── Student Profile ────────────────────────────────────────────────────────────

model StudentGoal {
  id          String    @id @default(cuid())
  userId      String
  description String
  category    String? // e.g. consistency | technique | competition | fitness | mindset (free-form)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competition {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        DateTime @db.Date
  location    String?
  division    String?
  weightClass String?
  result      String?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RankPromotion {
  id           String   @id @default(cuid())
  studentId    String
  promotedById String
  belt         Belt
  stripes      Int
  date         DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now())

  student    User @relation("StudentRank", fields: [studentId], references: [id])
  promotedBy User @relation("RankGivenBy", fields: [promotedById], references: [id])
}

// ── Instructor Tools ───────────────────────────────────────────────────────────

model StudentNote {
  id           String   @id @default(cuid())
  studentId    String
  instructorId String
  content      String
