// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum Role {
  admin
  instructor
  student
}

enum ClassType {
  gi
  nogi
  open_mat
  kids
  competition_prep
  seminar
  fundamentals
  nogi_fundamentals
  muay_thai
  wrestling
  self_defense
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum CommitmentStatus {
  committed
  maybe
  not_attending
}

enum LessonStatus {
  pending
  confirmed
  completed
  cancelled
}

enum Belt {
  white
  blue
  purple
  brown
  black
  coral
  red
}

enum ForumType {
  class_forum
  general
  announcement
  private_lesson
}

enum PostType {
  text
  video_link
  question
  announcement
}

enum NotificationType {
  class_update
  instructor_note
  private_message
  checkin_prompt
  feedback_prompt
  general
}

enum CheckInSource {
  manual
  app
  qr_code
}

enum FeedbackSentiment {
  positive
  neutral
  negative
  concern
}

// ── Auth (NextAuth) ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             Role      @default(student)
  onboardingDone   Boolean   @default(false)

  // Profile
  bio              String?
  phone            String?
  emergencyContact String?
  avatarUrl        String?

  // Rank
  belt             Belt      @default(white)
  stripes          Int       @default(0)
  weightClass      String?

  // QR check-in token
  qrToken              String  @unique @default(cuid())

  // Journal settings
  defaultJournalPrompts String?

  // Notification preferences
  notifyClassUpdates    Boolean @default(true)
  notifyInstructorNotes Boolean @default(true)
  notifyPrivateMessages Boolean @default(true)
  notifyCheckinPrompts  Boolean @default(true)
  notifyFeedbackPrompts Boolean @default(true)
  notifyByEmail         Boolean @default(false)
  allowDmsFromStudents  Boolean @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // NextAuth relations
  accounts         Account[]
  sessions         Session[]

  // App relations
  taughtClasses        Class[]           @relation("ClassInstructor")
  commitments          Commitment[]
  attendanceRecords    Attendance[]
  lessonsRequested     PrivateLesson[]   @relation("LessonRequester")
  lessonsTeaching      PrivateLesson[]   @relation("LessonInstructor")
  lessonsAsUke         PrivateLesson[]   @relation("LessonUke")
  posts                Post[]
  forumSubscriptions   ForumSubscription[]
  goalsAsStudent       StudentGoal[]
  competitions         Competition[]
  rankHistory          RankPromotion[]   @relation("StudentRank")
  rankPromotionsGiven  RankPromotion[]   @relation("RankGivenBy")
  studentNotes         StudentNote[]     @relation("NoteSubject")
  instructorNotes      StudentNote[]     @relation("NoteAuthor")
  lessonPlansAuthored  LessonPlan[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  sentMessages         DirectMessage[]   @relation("SentMessages")
  receivedMessages     DirectMessage[]   @relation("ReceivedMessages")
  trainingLogs         TrainingLog[]
  classFeedback        ClassFeedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ── Classes ────────────────────────────────────────────────────────────────────

model Class {
  id           String      @id @default(cuid())
  instructorId String
  title        String
  description  String?
  type         ClassType   @default(gi)
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  location     String?
  isActive     Boolean     @default(true)
  maxStudents  Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  instructor   User        @relation("ClassInstructor", fields: [instructorId], references: [id])
  sessions     ClassSession[]
  forum        Forum?
  lessonPlans  LessonPlan[]
}

model ClassSession {
  id          String    @id @default(cuid())
  classId     String
  date        DateTime  @db.Date
  cancelled   Boolean   @default(false)
  cancelNote  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  commitments  Commitment[]
  attendance   Attendance[]
  trainingLogs TrainingLog[]
  feedback     ClassFeedback[]

  @@unique([classId, date])
}

model Commitment {
  id             String           @id @default(cuid())
  userId         String
  classSessionId String
  status         CommitmentStatus @default(committed)
  weightClass    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

model Attendance {
  id             String        @id @default(cuid())
  userId         String
  classSessionId String
  attended       Boolean       @default(true)
  markedById     String
  checkedInAt    DateTime?
  checkInSource  CheckInSource @default(manual)
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id])
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, classSessionId])
}

// ── Private Lessons ────────────────────────────────────────────────────────────

model PrivateLesson {
  id           String        @id @default(cuid())
  requesterId  String
  instructorId String
  ukeId        String?
  scheduledAt  DateTime
  durationMins Int           @default(60)
  status       LessonStatus  @default(pending)
  location     String?
  notes        String?
  price        Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  requester    User          @relation("LessonRequester", fields: [requesterId], references: [id])
  instructor   User          @relation("LessonInstructor", fields: [instructorId], references: [id])
  uke          User?         @relation("LessonUke", fields: [ukeId], references: [id])
  messages     LessonMessage[]
}

model LessonMessage {
  id        String   @id @default(cuid())
  lessonId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  lesson PrivateLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ── Forums & Posts ─────────────────────────────────────────────────────────────

model Forum {
  id          String    @id @default(cuid())
  type        ForumType
  classId     String?   @unique
  title       String
  description String?
  createdAt   DateTime  @default(now())

  class         Class?             @relation(fields: [classId], references: [id], onDelete: Cascade)
  posts         Post[]
  subscriptions ForumSubscription[]
}

model Post {
  id        String   @id @default(cuid())
  forumId   String
  authorId  String
  content   String
  type      PostType @default(text)
  videoUrl  String?
  parentId  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forum    Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author   User   @relation(fields: [authorId], references: [id])
  parent   Post?  @relation("PostReplies", fields: [parentId], references: [id])
  replies  Post[] @relation("PostReplies")
}

model ForumSubscription {
  id        String   @id @default(cuid())
  userId    String
  forumId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  forum Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@unique([userId, forumId])
}

// ── Student Profile ────────────────────────────────────────────────────────────

model StudentGoal {
  id          String    @id @default(cuid())
  userId      String
  description String
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competition {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        DateTime @db.Date
  location    String?
  division    String?
  weightClass String?
  result      String?
  notes       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RankPromotion {
  id           String   @id @default(cuid())
  studentId    String
  promotedById String
  belt         Belt
  stripes      Int
  date         DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now())

  student     User @relation("StudentRank", fields: [studentId], references: [id])
  promotedBy  User @relation("RankGivenBy", fields: [promotedById], references: [id])
}

// ── Instructor Tools ───────────────────────────────────────────────────────────

model StudentNote {
  id           String   @id @default(cuid())
  studentId    String
  instructorId String
  content      String
  isPrivate    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    User @relation("NoteSubject", fields: [studentId], references: [id], onDelete: Cascade)
  instructor User @relation("NoteAuthor", fields: [instructorId], references: [id])
}

model LessonPlan {
  id           String   @id @default(cuid())
  instructorId String
  classId      String?
  title        String
  techniques   String?
  notes        String?
  videoUrls    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor User   @relation(fields: [instructorId], references: [id])
  class      Class? @relation(fields: [classId], references: [id])
}

// ── Notifications ──────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

// ── Direct Messages ────────────────────────────────────────────────────────────

model DirectMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("SentMessages",     fields: [senderId],    references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

// ── Training Journal ───────────────────────────────────────────────────────────

model TrainingLog {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId  String?
  classSession    ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  isPrivate       Boolean       @default(false)
  isGuided        Boolean       @default(false)
  freeFormContent String?
  guidedResponses Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── Class Feedback ─────────────────────────────────────────────────────────────

model ClassFeedback {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId  String
  classSession    ClassSession      @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  sentiment       FeedbackSentiment
  rating          Int?
  responses       Json
  reviewRequested Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@unique([userId, classSessionId])
}

// ── Push Subscriptions ─────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ── Gym Settings ───────────────────────────────────────────────────────────────

model GymSettings {
  id        String   @id @default(cuid())
  reviewUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
